---
interface Props {
  code: string;
  label?: string;
}

const { code, label = 'Terminal' } = Astro.props;
const trimmedCode = code.trim();
---

<figure
  class="w-full max-w-full min-w-0 overflow-hidden rounded-md border border-surface-border bg-muted"
  data-code-block
>
  <figcaption
    class="flex items-center justify-between gap-3 border-b border-surface-border bg-muted/40 px-3 py-2"
  >
    <span
      class="text-xs font-medium tracking-wide text-muted-foreground uppercase"
    >
      {label}
    </span>
    <button
      type="button"
      data-code-block-copy
      class="inline-flex cursor-pointer items-center gap-1.5 rounded-md border-0 bg-transparent px-2 py-1 text-xs text-muted-foreground transition-colors hover:bg-muted hover:text-foreground"
      aria-label="Copy code to clipboard"
    >
      <svg
        aria-hidden="true"
        class="size-3.5"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <rect width="14" height="14" x="8" y="8" rx="2" ry="2"></rect>
        <path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"></path>
      </svg>
      <span data-copy-label>Copy</span>
    </button>
  </figcaption>
  <div class="min-w-0 overflow-x-auto">
    <pre
      class="m-0 min-w-0 bg-muted px-4 py-3.5 text-[0.8125rem] leading-relaxed"
    ><code class="block w-max min-w-full font-mono whitespace-pre text-foreground">{trimmedCode}</code></pre>
  </div>
</figure>
