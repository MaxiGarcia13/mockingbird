---
import "../styles/global.css";
import packageJson from "../../../../package.json";

interface Props {
  title?: string;
  description?: string;
}

const siteName = "Mockingbird";
const githubUrl = packageJson.homepage;

const {
  title = `${siteName} — HTTP mocking for API debugging`,
  description = packageJson.description,
} = Astro.props;

const pageUrl = "https://mockingbird-landing.vercel.app";
const imageUrl = new URL("/mockingbird.png", pageUrl).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={pageUrl} />
    <link rel="icon" type="image/png" href="/favicon.png" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:image" content={imageUrl} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <meta name="twitter:url" content={pageUrl} />
  </head>
  <body class="min-h-dvh antialiased">
    <div class="flex min-h-dvh flex-col">
      <header
        class="sticky top-0 z-10 flex items-center justify-between gap-4 border-b border-surface-border bg-background/88 px-6 py-3.5 backdrop-blur-md"
      >
        <a
          class="inline-flex items-center gap-2.5 font-semibold no-underline"
          href="/"
        >
          <img
            class="rounded-md"
            src="/favicon.png"
            alt=""
            width="32"
            height="32"
          />
          <span>Mockingbird</span>
        </a>
        <nav class="flex items-center gap-5 text-sm">
          <a
            class="hidden text-muted-foreground no-underline transition-colors hover:text-foreground sm:inline"
            href="#workflows"
          >
            Workflows
          </a>
          <a
            class="hidden text-muted-foreground no-underline transition-colors hover:text-foreground sm:inline"
            href="#extension-steps"
          >
            Extension
          </a>
          <a
            class="hidden text-muted-foreground no-underline transition-colors hover:text-foreground sm:inline"
            href="#local-app-steps"
          >
            Local app
          </a>
          <a
            class="inline-flex items-center gap-1.5 rounded-md border border-surface-border bg-surface px-3 py-1.5 text-muted-foreground no-underline transition-colors hover:text-foreground"
            href={githubUrl}
            target="_blank"
            rel="noreferrer"
          >
            <svg
              aria-hidden="true"
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="currentColor"
            >
              <path
                d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"
              ></path>
            </svg>
            GitHub
          </a>
        </nav>
      </header>

      <slot />

      <footer
        class="mt-auto border-t border-surface-border px-6 py-8 text-center text-sm text-muted-foreground"
      >
        <p>
          Mockingbird — HTTP mocking for development.
          <a
            class="text-accent no-underline hover:underline"
            href={githubUrl}
            target="_blank"
            rel="noreferrer"
          >
            View on GitHub
          </a>
        </p>
      </footer>
    </div>
    <script>
      import "../scripts/code-block-copy.ts";
    </script>
  </body>
</html>
