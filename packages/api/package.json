{
  "name": "@maxigarcia/mockingbird-api",
  "type": "module",
  "version": "0.9.1",
  "scripts": {
    "build": "tsc",
    "start": "nodemon --env-file-if-exists .env --watch src --watch .mockingbird -e ts,json --exec 'tsx src/server.ts'",
    "dev": "npm run start",
    "clean": "rm -rf dist node_modules"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^9.1.3",
    "@maxigarcia/js-utils": "^1.12.0",
    "@maxigarcia/mockingbird-app": "*",
    "@maxigarcia/mockingbird-types": "*",
    "fastify": "^5.8.5"
  },
  "devDependencies": {
    "nodemon": "^3.1.14",
    "tsx": "^4.22.3"
  }
}
