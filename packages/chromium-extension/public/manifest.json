{
  "manifest_version": 3,
  "name": "Mockingbird",
  "version": "1.0",
  "description": "A chromium extension for Mockingbird. It intercepts requests and serves mock responses.",
  "action": {
    "default_popup": "./index.html",
    "default_icon": {
      "16": "./favicon.png",
      "48": "./favicon.png",
      "128": "./favicon.png"
    }
  },
  "permissions": [
    "storage"
  ],
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["scripts/interceptor/fetch.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["scripts/interceptor/bridge.js"],
      "run_at": "document_start"
    }
  ]
}
