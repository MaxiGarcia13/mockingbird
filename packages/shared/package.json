{
  "name": "@maxigarcia/mockingbird-shared",
  "type": "module",
  "version": "0.3.0",
  "description": "A collection of shared hooks and components for Mockingbird.",
  "author": "Maximiliano Garcia Mortigliengo",
  "license": "ISC",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "default": "./src/index.ts"
    },
    "./components": {
      "types": "./dist/types/components/index.d.ts",
      "default": "./src/components/index.ts"
    },
    "./components/*": {
      "types": "./dist/types/components/*.d.ts",
      "default": "./src/components/*.tsx"
    },
    "./components/editor": {
      "types": "./dist/types/components/editor/index.d.ts",
      "default": "./src/components/editor/index.ts"
    },
    "./components/tabs": {
      "types": "./dist/types/components/tabs/index.d.ts",
      "default": "./src/components/tabs/index.ts"
    },
    "./components/tooltip": {
      "types": "./dist/types/components/tooltip/index.d.ts",
      "default": "./src/components/tooltip/index.ts"
    },
    "./components/icons": {
      "types": "./dist/types/components/icons/index.d.ts",
      "default": "./src/components/icons/index.ts"
    },
    "./components/overrides-panel": {
      "types": "./dist/types/components/overrides-panel/index.d.ts",
      "default": "./src/components/overrides-panel/index.ts"
    },
    "./hooks": {
      "types": "./dist/types/hooks/index.d.ts",
      "default": "./src/hooks/index.ts"
    },
    "./hooks/*": {
      "types": "./dist/types/hooks/*.d.ts",
      "default": "./src/hooks/*.ts"
    },
    "./utils": {
      "types": "./dist/types/utils/index.d.ts",
      "default": "./src/utils/index.ts"
    },
    "./utils/*": {
      "types": "./dist/types/utils/*.d.ts",
      "default": "./src/utils/*.ts"
    },
    "./store/*": {
      "types": "./dist/types/store/*.d.ts",
      "default": "./src/store/*.ts"
    },
    "./mockingbird.css": "./src/index.css"
  },
  "types": "./dist/types/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist node_modules package-lock.json"
  },
  "peerDependencies": {
    "monaco-editor": "^0.55.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zustand": "^5.0.13"
  },
  "dependencies": {
    "@maxigarcia/js-utils": "^1.12.0",
    "@maxigarcia/mockingbird-types": "*"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "tailwindcss": "^4.3.0"
  }
}
