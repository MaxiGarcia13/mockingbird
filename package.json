{
  "name": "mockingbird",
  "type": "module",
  "version": "0.0.0",
  "description": "A lightweight HTTP request interceptor and mocking tool for seamless API debugging and network manipulation.",
  "author": "Maximiliano Garcia Mortigliengo",
  "license": "ISC",
  "homepage": "https://github.com/MaxiGarcia13/mockingbird#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MaxiGarcia13/mockingbird.git"
  },
  "bugs": {
    "url": "https://github.com/MaxiGarcia13/mockingbird/issues"
  },
  "workspaces": [
    "packages/*"
  ],
  "keywords": [
    "http-interceptor",
    "request-modification",
    "response-manipulation",
    "api-mocking",
    "network-traffic-control",
    "api-debugging",
    "frontend-testing",
    "mock-responses",
    "url-redirect",
    "header-modifier",
    "developer-tools",
    "local-development"
  ],
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "build": "nx run-many -t build",
    "start": "nx run-many -t start",
    "dev": "nx run mockingbird:dev",
    "dev:api": "nx run mockingbird:dev",
    "start:api": "nx run mockingbird:start",
    "build:api": "nx run mockingbird:build"
  },
  "devDependencies": {
    "@maxigarcia/eslint-config": "^1.8.0",
    "@nx/js": "^22.7.3",
    "@types/node": "^25.9.1",
    "nx": "^22.7.3",
    "typescript": "^6.0.3"
  }
}
