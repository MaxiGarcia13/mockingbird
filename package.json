{
  "name": "mockingbird",
  "type": "module",
  "version": "0.0.0",
  "description": "A lightweight HTTP request interceptor and mocking tool for seamless API debugging and network manipulation.",
  "author": "Maximiliano Garcia Mortigliengo",
  "license": "ISC",
  "homepage": "https://github.com/MaxiGarcia13/mockingbird#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MaxiGarcia13/mockingbird.git"
  },
  "bugs": {
    "url": "https://github.com/MaxiGarcia13/mockingbird/issues"
  },
  "workspaces": [
    "packages/*"
  ],
  "keywords": [
    "http-interceptor",
    "request-modification",
    "response-manipulation",
    "api-mocking",
    "network-traffic-control",
    "api-debugging",
    "frontend-testing",
    "mock-responses",
    "url-redirect",
    "header-modifier",
    "developer-tools",
    "local-development"
  ],
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "build": "nx run-many -t build",
    "dev": "nx run mockingbird-api:dev",
    "dev:app": "nx run mockingbird-app:dev",
    "dev:chromium-extension": "nx run mockingbird-chromium-extension:dev",
    "dev:landing": "nx run mockingbird-landing:dev",
    "prestart": "npm run build",
    "start": "nx run mockingbird-api:start",
    "clean": "nx reset && nx run-many -t clean && rm -rf node_modules package-lock.json",
    "phoenix": "npm run clean && npm install && npm run build",
    "bump-version": "nx release --skip-publish",
    "test:unit": "nx run-many -t test:unit"
  },
  "devDependencies": {
    "@eslint-react/eslint-plugin": "^3.0.0",
    "@maxigarcia/eslint-config": "^1.8.0",
    "@nx/js": "^22.7.3",
    "@types/node": "^25.9.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "nx": "^22.7.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "tailwindcss": "^4.3.0"
  }
}
