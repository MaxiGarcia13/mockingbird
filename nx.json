{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "defaultBase": "main",
  "targetDefaults": {
    "build": {
      "dependsOn": ["^build"],
      "cache": true,
      "outputs": ["{projectRoot}/dist"]
    },
    "lint": {
      "cache": true
    },
    "dev": {
      "continuous": true
    }
  },
  "release": {
    "projects": [
      "packages/api",
      "packages/app"
    ],
    "projectsRelationship": "independent",
    "releaseTag": {
      "pattern": "{projectName}@{version}"
    },
    "version": {
      "conventionalCommits": true,
      "preVersionCommand": "npx nx run-many -t build -p packages/api,packages/app"
    },
    "changelog": {
      "workspaceChangelog": false,
      "projectChangelogs": true
    },
    "git": {
      "commit": true,
      "tag": true,
      "commitMessage": "chore(release): version packages"
    }
  },
  "analytics": false
}
